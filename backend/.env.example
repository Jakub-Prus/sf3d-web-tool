PROJECT_NAME=SF3D Web Tool API
API_PREFIX=/api
# Local Windows GPU preset:
# SF3D_INFERENCE_MODE=real
# SF3D_FORCE_CPU=false
# After installing CUDA-enabled PyTorch and the CUDA toolkit, run:
# python .\scripts\patch_windows_torch_cuda_header.py
# powershell -ExecutionPolicy Bypass -File .\scripts\rebuild_sf3d_windows_cuda.ps1
#
# Docker/Linux CPU deploy preset:
# SF3D_INFERENCE_MODE=real
# SF3D_FORCE_CPU=true
# Modes:
# - auto: use the official SF3D runner when it is present and importable, otherwise fall back to local preview generation
# - local: always generate a lightweight local GLB preview mesh
# - mock: return placeholder artifacts only
# - real: require the official SF3D runner
SF3D_INFERENCE_MODE=auto
SF3D_REPO_DIR="c:\github\my-projects\sf3d-web-tool\models\stable-fast-3d"
SF3D_PYTHON_EXECUTABLE="c:\github\my-projects\sf3d-web-tool\.venv\Scripts\python.exe"
SF3D_IMPORT_PROBE_TIMEOUT_SECONDS=30
FRONTEND_ORIGIN=http://localhost:3000
# Legacy fallback flag. Prefer SF3D_INFERENCE_MODE instead.
# SF3D_ENABLE_MOCK_INFERENCE=true
SF3D_FORCE_CPU=false
SF3D_OUTPUT_DIR=../outputs
SF3D_MAX_UPLOAD_BYTES=10485760
